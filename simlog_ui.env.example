# Copiar a .env o exportar antes de `streamlit run` (no commitear secretos reales).
# Host para URLs por defecto (sustituir si el navegador no es local)
SIMLOG_UI_HOST=127.0.0.1

# Timeouts para subprocess desde el dashboard (segundos). Spark en frío puede tardar >10 min.
# SIMLOG_INGESTA_TIMEOUT_SEC=300
# SIMLOG_SPARK_TIMEOUT_SEC=1800

# --- Por servicio: URL (prioridad), puerto, usuario, contraseña ---
# HDFS NameNode UI
# SIMLOG_UI_HDFS_URL=http://127.0.0.1:9870
# SIMLOG_UI_HDFS_PORT=9870
# SIMLOG_UI_HDFS_USER=
# SIMLOG_UI_HDFS_PASSWORD=

# Kafka (Kafdrop, AKHQ, etc.)
# SIMLOG_UI_KAFKA_URL=http://127.0.0.1:8095
# SIMLOG_UI_KAFKA_PORT=8095
# SIMLOG_UI_KAFKA_USER=
# SIMLOG_UI_KAFKA_PASSWORD=

# Cassandra (Reaper, Studio, etc.; vacío = solo cqlsh :9042)
# SIMLOG_UI_CASSANDRA_URL=
# SIMLOG_UI_CASSANDRA_PORT=9042
# SIMLOG_UI_CASSANDRA_USER=cassandra
# SIMLOG_UI_CASSANDRA_PASSWORD=

# Spark Master UI
# SIMLOG_UI_SPARK_URL=http://127.0.0.1:8081
# SIMLOG_UI_SPARK_PORT=8081

# Hive / consola web (p. ej. Hue)
# SIMLOG_UI_HIVE_URL=http://127.0.0.1:8888
# SIMLOG_UI_HIVE_PORT=8888

# Airflow
# SIMLOG_UI_AIRFLOW_URL=http://127.0.0.1:8080
# SIMLOG_UI_AIRFLOW_PORT=8080
# SIMLOG_UI_AIRFLOW_USER=admin
# SIMLOG_UI_AIRFLOW_PASSWORD=tu_clave

# NiFi
# SIMLOG_UI_NIFI_URL=https://127.0.0.1:8443/nifi
# SIMLOG_UI_NIFI_PORT=8443
# SIMLOG_UI_NIFI_USER=
# SIMLOG_UI_NIFI_PASSWORD=

# Mostrar contraseñas en claro en el dashboard (solo dev)
# SIMLOG_UI_REVEAL_SECRETS=0
