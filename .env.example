# Variables de entorno para demo rapida (Codespaces/local)
# Copia este fichero a .env y ajusta valores segun tu entorno.

# OpenWeather (opcional en demo; sin clave se muestran mensajes de fallback)
API_WEATHER_KEY=
OWM_API_KEY=
OPENWEATHER_API_KEY=

# Demo ligera: evita dependencia de Hive en presentacion
SIMLOG_ENABLE_HIVE=0

# Timeouts mas tolerantes para primeras ejecuciones en cloud
SIMLOG_INGESTA_TIMEOUT_SEC=600
SIMLOG_SPARK_TIMEOUT_SEC=2400

# Cassandra por defecto en local/compose
CASSANDRA_HOST=127.0.0.1
