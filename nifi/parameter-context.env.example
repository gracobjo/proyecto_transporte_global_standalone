# Copiar valores al Parameter Context de NiFi (sin commitear secretos reales)
# Renombrar a .env solo en tu máquina y excluir de git

KAFKA_BOOTSTRAP=localhost:9092
TOPIC_DGT_RAW=transporte_dgt_raw
TOPIC_RAW=transporte_raw
TOPIC_FILTERED=transporte_filtered

# Clima: Open-Meteo por defecto (sin clave). Opcional: URL multi-hub completa.
# SIMLOG_OPEN_METEO_MULTI_HUBS_URL=https://api.open-meteo.com/v1/forecast?latitude=...
DGT_DATEX2_URL=https://nap.dgt.es/datex2/v3/dgt/SituationPublication/datex2_v36.xml

HDFS_RAW_BASE=/user/hadoop/transporte_backup/nifi_raw
HDFS_CURATED_BASE=/user/hadoop/transporte_backup/nifi_curated
HDFS_BACKUP_PATH=/user/hadoop/transporte_backup
HADOOP_CONF_RESOURCES=/etc/hadoop/conf/core-site.xml,/etc/hadoop/conf/hdfs-site.xml

CASSANDRA_HOST=127.0.0.1

SPARK_HOME=/opt/spark
SPARK_MASTER=yarn
# Si no hay YARN: SPARK_MASTER=local
DEPLOY_MODE=client

PROJECT_ROOT=/home/hadoop/proyecto_transporte_global

HIVE_JDBC_URL=jdbc:hive2://localhost:10000/logistica_analytics
